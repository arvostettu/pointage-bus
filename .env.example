# ----------------------------------------------------------------------
# Pointage Bus — variables d'environnement
# Copier en .env et compléter. NE JAMAIS committer le .env réel.
# ----------------------------------------------------------------------

# --- Obligatoire ---
# ID extrait de l'URL https://docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEET_ID=
# Mot de passe d'accès à l'app
APP_PASSWORD=
# Clé de signature des cookies (16+ caractères aléatoires).
# Générer : python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# --- Google / chemins (défauts ci-dessous) ---
GOOGLE_SERVICE_ACCOUNT_FILE=/secrets/service-account.json
GOOGLE_SHEET_TAB=Sheet1
GOOGLE_SHEET_TAB_OCCASIONNEL=Sheet2

# --- Colonnes Sheet1 (service régulier) ---
COL_DATE=Date
COL_ALLER=Aller
COL_RETOUR=Retour

# --- Colonnes Sheet2 (service occasionnel) ---
COL_OCC_DATE=Date
COL_OCC_HEURE_DEPART=Heure départ
COL_OCC_HEURE_ARRIVEE=Heure arrivée
COL_OCC_KM_DEPART=Km départ
COL_OCC_KM_ARRIVEE=Km arrivée
COL_OCC_KM_TOTAL=Km total
COL_OCC_ADULTES=Adultes
COL_OCC_ENFANTS=Enfants

# --- Formats & fuseau ---
DATE_FORMAT=%Y-%m-%d
TIME_FORMAT=%H:%M
TZ=Europe/Paris
MORNING_CUTOFF_HOUR=12

# --- Plafonds de validation ---
MAX_PASSENGERS=999
MAX_KM=9999999
MAX_PASSENGERS_OCC=99

# --- Session ---
SESSION_LIFETIME_DAYS=30
# Mettre à true si l'app est servie en HTTPS (derrière un reverse proxy).
COOKIE_SECURE=false
